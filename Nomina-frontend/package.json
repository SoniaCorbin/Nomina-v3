{
  "name": "nomina-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron-dist/main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:src": "vite build --mode src",
    "preview": "vite preview",
    "electron:build": "tsc -p electron/tsconfig.json",
    "electron:dev": "npm run electron:build && concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:dist": "npm run build && npm run electron:build && electron-builder",
    "migrate": "node -e \"console.error('Les migrations Prisma se font dans Nomina-backend. Utilise: npm run backend:migrate'); process.exit(1)\"",
    "seed": "node -e \"console.error('Le seed se fait dans Nomina-backend. Utilise: npm run backend:seed'); process.exit(1)\"",
    "backend:migrate": "npm --prefix ../Nomina-backend run migrate",
    "backend:migrate:deploy": "npm --prefix ../Nomina-backend run migrate:deploy",
    "backend:seed": "npm --prefix ../Nomina-backend run seed",
    "backend:seed:realism": "npm --prefix ../Nomina-backend run seed:realism"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SoniaCorbin/Nomina-v3.git"
  },
  "keywords": [],
  "author": "Sonia Corbin",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/SoniaCorbin/Nomina-v3/issues"
  },
  "homepage": "https://github.com/SoniaCorbin/Nomina-v3#readme",
  "description": "Nomina — API Génératrice & Narratrice de Noms",
  "dependencies": {
    "@clerk/clerk-react": "^5.59.5",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-aspect-ratio": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-context-menu": "^2.2.6",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-hover-card": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-navigation-menu": "^1.2.5",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-toggle-group": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.487.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.55.0",
    "react-resizable-panels": "^2.1.7",
    "react-router-dom": "^7.13.0",
    "recharts": "^2.15.2",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.4.1",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "6.3.5",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.nomina.desktop",
    "productName": "Nomina",
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "assets/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/logo5.png"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}