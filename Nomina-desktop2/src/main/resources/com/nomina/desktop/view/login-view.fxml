<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" styleClass="content" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.nomina.desktop.controller.LoginController">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <children>
        <Label text="Connexion API (Token)" styleClass="section-title"/>

        <Label text="URL API"/>
        <TextField fx:id="apiUrlField" promptText="http://localhost:3000/api"/>

        <Label text="Token Bearer (Clerk)"/>
        <TextField fx:id="tokenField" promptText="colle ton JWT ici"/>

        <HBox spacing="10.0">
            <children>
                <Button fx:id="validateButton" text="Valider /auth/me" onAction="#onValidateToken"/>
                <Button text="Ouvrir sign-in Clerk" onAction="#onOpenSignIn"/>
                <Button text="Ouvrir sign-up Clerk" onAction="#onOpenSignUp"/>
            </children>
        </HBox>

        <ProgressIndicator fx:id="loadingIndicator" visible="false" managed="false" prefHeight="28" prefWidth="28"/>
        <Label fx:id="infoLabel" text="Entre ton URL API et ton token, puis valide." styleClass="muted" wrapText="true"/>
    </children>
</VBox>
