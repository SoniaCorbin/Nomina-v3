<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" styleClass="content" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.nomina.desktop.controller.DashboardController">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <children>
        <HBox spacing="12.0">
            <children>
                <Label text="Dashboard" styleClass="section-title"/>
                <Button text="Rafraîchir" onAction="#onRefresh"/>
                <ProgressIndicator fx:id="loadingIndicator" visible="false" managed="false" prefHeight="24" prefWidth="24"/>
            </children>
        </HBox>

        <GridPane hgap="10" vgap="10">
            <children>
                <Label text="Utilisateur:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="userLabel" text="-" styleClass="muted" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Rôle:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="roleLabel" text="-" styleClass="muted" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Total Concepts:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="conceptsTotalLabel" text="0" styleClass="stat" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Total Cultures:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <Label fx:id="culturesTotalLabel" text="0" styleClass="stat" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="Total Catégories:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <Label fx:id="categoriesTotalLabel" text="0" styleClass="stat" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
            </children>
        </GridPane>
    </children>
</VBox>