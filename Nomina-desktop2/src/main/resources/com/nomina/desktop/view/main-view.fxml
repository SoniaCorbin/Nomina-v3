<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" prefHeight="760.0" prefWidth="1180.0" styleClass="app-root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nomina.desktop.controller.MainController">

    <left>
        <VBox prefWidth="240.0" spacing="10.0" styleClass="sidebar">
            <padding>
                <Insets bottom="14" left="12" right="12" top="14" />
            </padding>
            <children>
               <Button fx:id="dashboardButton" maxWidth="Infinity" onAction="#onOpenDashboard" text="Dashboard" />
               <Button fx:id="loginButton" maxWidth="Infinity" onAction="#onOpenLogin" text="Connexion / Token" />
               <Button fx:id="conceptsButton" maxWidth="Infinity" onAction="#onOpenConcepts" text="CRUD Concepts" />
               <Button fx:id="categoriesButton" maxWidth="Infinity" onAction="#onOpenCategories" text="CRUD Categories" />
               <Button fx:id="culturesButton" maxWidth="Infinity" onAction="#onOpenCultures" text="CRUD Cultures" />
               <Button fx:id="universButton" maxWidth="Infinity" onAction="#onOpenUnivers" text="CRUD Univers" />
                  <Button fx:id="usersButton" maxWidth="Infinity" onAction="#onOpenUsers" text="CRUD Users" />
               <Button fx:id="logoutButton" maxWidth="Infinity" onAction="#onLogout" styleClass="danger" text="Déconnexion" />
            </children>
        </VBox>
    </left>
   <top>
      <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="topbar" BorderPane.alignment="CENTER">
         <padding>
            <Insets top="10" right="14" bottom="10" left="14" />
         </padding>
         <children>
            <ImageView fitHeight="26.0" preserveRatio="true">
               <image>
                  <Image url="@../images/logo5.png" />
               </image>
            </ImageView>
            <Label styleClass="title" text="Nomina Desktop" />
            <Label fx:id="apiUrlLabel" styleClass="muted" text="API" />
            <Label fx:id="authStatusLabel" styleClass="badge" text="Non connecté" />
         </children>
      </HBox>
   </top>

</BorderPane>
