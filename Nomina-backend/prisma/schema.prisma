// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql" 
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  email     String   @unique
  role      String   @default("Editor") // Ex: Admin, Editor, Viewer
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UniversThematique {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  description String?
  imageUrl    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  categories  Categorie[]
  socialClasses SocialClass[]
  occupations  Occupation[]
  organizations Organization[]
  relationTypes RelationType[]
  events       Event[]
}

model Categorie {
  id          Int               @id @default(autoincrement())
  name        String
  description String?
  imageUrl    String?
  universId   Int
  univers     UniversThematique @relation(fields: [universId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  nomPersonnages    Prenom[] // opposite relation field
  lieux             Lieux[]
  fragmentsHistoire FragmentsHistoire[] // opposite relation field
  titres            Titre[] // opposite relation field
  concepts          Concept[] // opposite relation field
  nomFamilles       NomFamille[] // opposite relation field
  personnages       Personnage[]
  creatures         Creature[]
  events            Event[]
  socialClasses     SocialClass[]
  occupations       Occupation[]
  organizations     Organization[]
  relationTypes     RelationType[]
}

model Culture {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  nomPersonnages    Prenom[] // opposite relation field
  fragmentsHistoire FragmentsHistoire[] // opposite relation field
  titres            Titre[] // opposite relation field
  nomFamilles       NomFamille[] // opposite relation field
  personnages       Personnage[]
  creatures         Creature[]
  events            Event[]
  socialClasses     SocialClass[]
  occupations       Occupation[]
  organizations     Organization[]
  relationTypes     RelationType[]
}

model NomFamille {
  id          Int        @id @default(autoincrement())
  valeur      String?    @unique
  cultureId   Int?
  culture     Culture?   @relation(fields: [cultureId], references: [id], onDelete: SetNull)
  categorieId Int?
  categorie   Categorie? @relation(fields: [categorieId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime?  @updatedAt

  personnages      Prenom[] // relation inverse
  personnagesReels Personnage[]
}

model Prenom {
  id           Int         @id @default(autoincrement())
  valeur       String?
  genre        String?
  cultureId    Int?
  culture      Culture?    @relation(fields: [cultureId], references: [id], onDelete: SetNull)
  categorieId  Int?
  categorie    Categorie?  @relation(fields: [categorieId], references: [id])
  nomFamilleId Int?
  nomFamille   NomFamille? @relation(fields: [nomFamilleId], references: [id])
  personnages  Personnage[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime?   @updatedAt

  @@map("NomPersonnage")
}

model Lieux {
  id          Int        @id @default(autoincrement())
  value       String
  type        String?
  imageUrl    String?

  parentId    Int?
  parent      Lieux?     @relation("LieuxHierarchy", fields: [parentId], references: [id])
  children    Lieux[]    @relation("LieuxHierarchy")

  categorieId Int?
  categorie   Categorie? @relation(fields: [categorieId], references: [id])

  bornHere    Personnage[] @relation("BirthPlace")
  livingHere  Personnage[] @relation("ResidencePlace")
  eventsHere  Event[]      @relation("EventPlace")

  createdAt   DateTime   @default(now())
  updatedAt   DateTime?  @updatedAt

  @@index([parentId])
  @@index([categorieId])
}

model FragmentsHistoire {
  id            Int        @id @default(autoincrement())
  texte         String
  appliesTo     String?
  genre         String?
  minNameLength Int?
  maxNameLength Int?
  cultureId     Int?
  culture       Culture?   @relation(fields: [cultureId], references: [id], onDelete: SetNull)
  categorieId   Int?
  categorie     Categorie? @relation(fields: [categorieId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Titre {
  id          Int        @id @default(autoincrement())
  valeur      String
  type        String?
  genre       String?
  cultureId   Int?
  culture     Culture?   @relation(fields: [cultureId], references: [id], onDelete: SetNull)
  categorieId Int?
  categorie   Categorie? @relation(fields: [categorieId], references: [id])
  personnages Personnage[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Personnage {
  id           Int        @id @default(autoincrement())
  prenomId     Int
  prenom       Prenom     @relation(fields: [prenomId], references: [id])
  nomFamilleId Int?
  nomFamille   NomFamille? @relation(fields: [nomFamilleId], references: [id])
  titreId      Int?
  titre        Titre?     @relation(fields: [titreId], references: [id])
  genre        String?
  biographie   String?

  birthYear    Int?

  socialClassId Int?
  socialClass   SocialClass? @relation(fields: [socialClassId], references: [id])

  occupationId Int?
  occupation   Occupation? @relation(fields: [occupationId], references: [id])

  birthPlaceId Int?
  birthPlace   Lieux?     @relation("BirthPlace", fields: [birthPlaceId], references: [id])
  residencePlaceId Int?
  residencePlace   Lieux? @relation("ResidencePlace", fields: [residencePlaceId], references: [id])

  cultureId    Int?
  culture      Culture?   @relation(fields: [cultureId], references: [id], onDelete: SetNull)
  categorieId  Int?
  categorie    Categorie? @relation(fields: [categorieId], references: [id])

  memberships   PersonnageOrganization[]
  fromRelations PersonnageRelation[] @relation("FromRelations")
  toRelations   PersonnageRelation[] @relation("ToRelations")
  events        PersonnageEvent[]

  creatures    Creature[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([birthYear])
  @@index([socialClassId])
  @@index([occupationId])
  @@index([birthPlaceId])
  @@index([residencePlaceId])
  @@index([cultureId])
  @@index([categorieId])
}

model Concept {
  id          Int        @id @default(autoincrement())
  valeur      String
  type        String?
  mood        String?
  keywords    String?
  categorieId Int?
  categorie   Categorie? @relation(fields: [categorieId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Creature {
  id          Int        @id @default(autoincrement())
  valeur      String
  type        String?
  description String?
  imageUrl    String?
  personnageId Int?
  personnage   Personnage? @relation(fields: [personnageId], references: [id])
  cultureId   Int?
  culture     Culture?   @relation(fields: [cultureId], references: [id], onDelete: SetNull)
  categorieId Int?
  categorie   Categorie? @relation(fields: [categorieId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model SocialClass {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  rank        Int?

  universId   Int?
  univers     UniversThematique? @relation(fields: [universId], references: [id])
  categorieId Int?
  categorie   Categorie?         @relation(fields: [categorieId], references: [id])
  cultureId   Int?
  culture     Culture?           @relation(fields: [cultureId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  personnages Personnage[]

  @@unique([name, universId, categorieId, cultureId])
  @@index([universId, categorieId])
  @@index([universId])
  @@index([categorieId])
  @@index([cultureId])
}

model Occupation {
  id          Int      @id @default(autoincrement())
  name        String
  description String?

  universId   Int?
  univers     UniversThematique? @relation(fields: [universId], references: [id])
  categorieId Int?
  categorie   Categorie?         @relation(fields: [categorieId], references: [id])
  cultureId   Int?
  culture     Culture?           @relation(fields: [cultureId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  personnages Personnage[]

  @@unique([name, universId, categorieId, cultureId])
  @@index([universId, categorieId])
  @@index([universId])
  @@index([categorieId])
  @@index([cultureId])
}

model Organization {
  id          Int      @id @default(autoincrement())
  name        String
  type        String?
  description String?
  imageUrl    String?

  universId   Int?
  univers     UniversThematique? @relation(fields: [universId], references: [id])
  categorieId Int?
  categorie   Categorie?         @relation(fields: [categorieId], references: [id])
  cultureId   Int?
  culture     Culture?           @relation(fields: [cultureId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships PersonnageOrganization[]

  @@unique([name, universId, categorieId, cultureId])
  @@index([universId, categorieId])
  @@index([universId])
  @@index([categorieId])
  @@index([cultureId])
}

model PersonnageOrganization {
  id             Int          @id @default(autoincrement())
  personnageId   Int
  personnage     Personnage   @relation(fields: [personnageId], references: [id])
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])

  role           String?
  startYear      Int?
  endYear        Int?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([personnageId, organizationId])
  @@index([organizationId])
}

model RelationType {
  id          Int      @id @default(autoincrement())
  code        String
  label       String
  description String?

  universId   Int?
  univers     UniversThematique? @relation(fields: [universId], references: [id])
  categorieId Int?
  categorie   Categorie?         @relation(fields: [categorieId], references: [id])
  cultureId   Int?
  culture     Culture?           @relation(fields: [cultureId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  relations   PersonnageRelation[]

  @@unique([code, universId, categorieId, cultureId])
  @@index([universId, categorieId])
  @@index([universId])
  @@index([categorieId])
  @@index([cultureId])
}

model PersonnageRelation {
  id               Int          @id @default(autoincrement())
  fromPersonnageId Int
  fromPersonnage   Personnage   @relation("FromRelations", fields: [fromPersonnageId], references: [id])
  toPersonnageId   Int
  toPersonnage     Personnage   @relation("ToRelations", fields: [toPersonnageId], references: [id])

  relationTypeId   Int
  relationType     RelationType @relation(fields: [relationTypeId], references: [id])

  strength         Int?
  note             String?

  startYear        Int?
  endYear          Int?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([fromPersonnageId])
  @@index([toPersonnageId])
  @@index([relationTypeId])
}

model Event {
  id           Int        @id @default(autoincrement())
  title        String
  summary      String?
  startYear    Int?
  endYear      Int?

  placeId      Int?
  place        Lieux?     @relation("EventPlace", fields: [placeId], references: [id])

  universId    Int?
  univers      UniversThematique? @relation(fields: [universId], references: [id])

  cultureId    Int?
  culture      Culture?   @relation(fields: [cultureId], references: [id], onDelete: SetNull)

  categorieId  Int?
  categorie    Categorie? @relation(fields: [categorieId], references: [id])

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  participants PersonnageEvent[]

  @@index([placeId])
  @@index([universId, categorieId])
  @@index([universId])
  @@index([categorieId])
  @@index([cultureId])
}

model PersonnageEvent {
  id           Int        @id @default(autoincrement())
  personnageId Int
  personnage   Personnage @relation(fields: [personnageId], references: [id])
  eventId      Int
  event        Event      @relation(fields: [eventId], references: [id])

  role         String?
  note         String?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([personnageId, eventId])
  @@index([eventId])
}

// ─── Billing ────────────────────────────────────────────────
// Ajouter ces modèles à la fin de prisma/schema.prisma
model Subscription {
  id                    Int      @id @default(autoincrement())
  clerkUserId           String   @unique            // Clerk user Id (ex: user_2abc...)
  stripeCustomerId      String?  @unique            // Stripe customer ID (cus_...)
  stripeSubscriptionId  String?  @unique            // Stripe subscription ID (sub_...)
  plan                  String   @default("free")   // "free" | "creator" | "studio"
  status                String   @default("active") // "active" | "canceled" | "past_due"

  // Quotas
  monthlyLimit          Int      @default(1000)     // Requetes max par mois
  currentUsage          Int      @default(0)        // Requetes utilisees ce mois
  periodStart           DateTime @default(now())    // Debut du cycle de facturation
  periodEnd             DateTime?                   // Fin du cycle (renouvele par webhook)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  usageLogs             UsageLog[]

  @@index([plan])
  @@index([periodEnd])
}

model UsageLog {
  id              Int         @id @default(autoincrement())
  subscriptionId  Int
  subscription    Subscription @relation(fields: [subscriptionId], references: [id])
  endpoint        String                             // ex: "/api/generate/npcs"
  tokenUsed       Int?                               // tokens OpenAi si applicable
  createdAt       DateTime     @default(now())

  @@index([subscriptionId, createdAt])
  @@index([createdAt])
}
